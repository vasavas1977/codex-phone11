{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "ios": {
        "image": "latest"
      }
    },
    "development-ios-existing-credentials": {
      "extends": "development",
      "env": {
        "PHONE11_BUNDLE_ID": "space.manus.phone11ai.t20260425073427",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.phone11.ai",
        "EXPO_PUBLIC_DEEP_LINK_SCHEME": "phone11"
      },
      "ios": {
        "image": "latest"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "preview-ios-existing-credentials": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "PHONE11_BUNDLE_ID": "space.manus.phone11ai.t20260425073427",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.phone11.ai",
        "EXPO_PUBLIC_DEEP_LINK_SCHEME": "phone11"
      },
      "ios": {
        "image": "latest"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
