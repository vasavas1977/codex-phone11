{
  "annotations": { "list": [] },
  "description": "CloudPhone11 — Infrastructure: CPU, Memory, Disk, Pod Health",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Pod Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "expr": "count(kube_pod_status_phase{namespace=\"cloudphone11\",phase=\"Running\"})",
        "legendFormat": "Running"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "title": "Pods Not Ready",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "count(kube_pod_status_phase{namespace=\"cloudphone11\",phase!=\"Running\"})",
        "legendFormat": "Not Ready"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "title": "Container Restarts (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"cloudphone11\"}[1h]))",
        "legendFormat": "Restarts"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "title": "Total CPU Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"cloudphone11\"}[5m]))",
        "legendFormat": "CPU Cores"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 } }
    },
    {
      "title": "Total Memory Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{namespace=\"cloudphone11\"})",
        "legendFormat": "Memory"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "DB Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{
        "expr": "pg_stat_activity_count",
        "legendFormat": "Active"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }] } } }
    },
    {
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"cloudphone11\"}[5m]))",
        "legendFormat": "{{ pod }}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Memory Usage by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"cloudphone11\"})",
        "legendFormat": "{{ pod }}"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Network I/O by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_network_receive_bytes_total{namespace=\"cloudphone11\"}[5m]))",
          "legendFormat": "{{ pod }} RX"
        },
        {
          "expr": "sum by (pod) (rate(container_network_transmit_bytes_total{namespace=\"cloudphone11\"}[5m]))",
          "legendFormat": "{{ pod }} TX"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "title": "Disk Usage (PVCs)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "kubelet_volume_stats_used_bytes{namespace=\"cloudphone11\"} / kubelet_volume_stats_capacity_bytes{namespace=\"cloudphone11\"}",
        "legendFormat": "{{ persistentvolumeclaim }}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 }] }
        }
      }
    },
    {
      "title": "PostgreSQL — Queries/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "rate(pg_stat_database_tup_fetched{datname=\"cloudphone11\"}[5m])", "legendFormat": "SELECT/s" },
        { "expr": "rate(pg_stat_database_tup_inserted{datname=\"cloudphone11\"}[5m])", "legendFormat": "INSERT/s" },
        { "expr": "rate(pg_stat_database_tup_updated{datname=\"cloudphone11\"}[5m])", "legendFormat": "UPDATE/s" },
        { "expr": "rate(pg_stat_database_tup_deleted{datname=\"cloudphone11\"}[5m])", "legendFormat": "DELETE/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Redis — Commands/s & Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "Commands/s" },
        { "expr": "redis_memory_used_bytes", "legendFormat": "Memory Used" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cloudphone11", "infrastructure", "kubernetes"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "CloudPhone11 — Infrastructure",
  "uid": "cloudphone11-infrastructure",
  "version": 1
}
