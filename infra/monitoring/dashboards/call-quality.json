{
  "annotations": { "list": [] },
  "description": "CloudPhone11 — Call Quality: MOS, Jitter, Packet Loss, RTP Stats",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Average MOS Score",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "avg(freeswitch_rtp_quality_mos)",
        "legendFormat": "MOS"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 1,
          "max": 5,
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 1 },
              { "color": "orange", "value": 2.5 },
              { "color": "yellow", "value": 3.5 },
              { "color": "green", "value": 4.0 }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Average Jitter",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "avg(freeswitch_rtp_jitter_ms)",
        "legendFormat": "Jitter"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 40 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "title": "Average Packet Loss",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "avg(freeswitch_rtp_packet_loss_percent)",
        "legendFormat": "Packet Loss"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 10,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Active RTP Streams",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "freeswitch_rtp_active_streams",
        "legendFormat": "Streams"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "MOS Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "avg(freeswitch_rtp_quality_mos)",
          "legendFormat": "Average MOS"
        },
        {
          "expr": "min(freeswitch_rtp_quality_mos)",
          "legendFormat": "Min MOS"
        },
        {
          "expr": "quantile(0.05, freeswitch_rtp_quality_mos)",
          "legendFormat": "P5 MOS (worst 5%)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 1,
          "max": 5,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 3.0 },
              { "color": "yellow", "value": 3.5 },
              { "color": "green", "value": 4.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Jitter Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "avg(freeswitch_rtp_jitter_ms)",
          "legendFormat": "Average Jitter"
        },
        {
          "expr": "max(freeswitch_rtp_jitter_ms)",
          "legendFormat": "Max Jitter"
        },
        {
          "expr": "quantile(0.95, freeswitch_rtp_jitter_ms)",
          "legendFormat": "P95 Jitter"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          }
        }
      }
    },
    {
      "title": "Packet Loss Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "avg(freeswitch_rtp_packet_loss_percent)",
          "legendFormat": "Average Loss %"
        },
        {
          "expr": "max(freeswitch_rtp_packet_loss_percent)",
          "legendFormat": "Max Loss %"
        },
        {
          "expr": "rate(freeswitch_rtp_packets_lost_total[5m])",
          "legendFormat": "Lost Packets/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "RTP Round-Trip Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "avg(freeswitch_rtp_rtt_ms)",
          "legendFormat": "Average RTT"
        },
        {
          "expr": "quantile(0.95, freeswitch_rtp_rtt_ms)",
          "legendFormat": "P95 RTT"
        },
        {
          "expr": "max(freeswitch_rtp_rtt_ms)",
          "legendFormat": "Max RTT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "title": "Call Quality Distribution (MOS Buckets)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "count(freeswitch_rtp_quality_mos >= 4.0)",
          "legendFormat": "Excellent (4.0+)"
        },
        {
          "expr": "count(freeswitch_rtp_quality_mos >= 3.5 and freeswitch_rtp_quality_mos < 4.0)",
          "legendFormat": "Good (3.5-4.0)"
        },
        {
          "expr": "count(freeswitch_rtp_quality_mos >= 3.0 and freeswitch_rtp_quality_mos < 3.5)",
          "legendFormat": "Fair (3.0-3.5)"
        },
        {
          "expr": "count(freeswitch_rtp_quality_mos < 3.0)",
          "legendFormat": "Poor (<3.0)"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Excellent (4.0+)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Good (3.5-4.0)" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "Fair (3.0-3.5)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "Poor (<3.0)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "title": "Codec Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [{
        "expr": "sum by (codec) (freeswitch_sessions_by_codec)",
        "legendFormat": "{{ codec }}"
      }],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cloudphone11", "call-quality", "rtp", "voip"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CloudPhone11 — Call Quality",
  "uid": "cloudphone11-call-quality",
  "version": 1
}
