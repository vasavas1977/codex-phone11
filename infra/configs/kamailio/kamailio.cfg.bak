#!KAMAILIO
# =============================================================================
# CloudPhone11 — Kamailio SIP Proxy Configuration
# =============================================================================
# Role: SIP registrar, proxy, load balancer, NAT traversal, WebSocket (WSS)
# Routes calls between mobile clients, FreeSWITCH, PSTN trunks, and Flexisip
# =============================================================================

#!substdef "!MY_DOMAIN!__SIP_DOMAIN__!g"
#!substdef "!MY_IP!__KAMAILIO_IP__!g"
#!substdef "!MY_WS_PORT!7443!g"
#!substdef "!FS_IP!__FREESWITCH_IP__!g"
#!substdef "!FS_PORT!5060!g"
#!substdef "!FLEXISIP_IP!__FLEXISIP_IP__!g"
#!substdef "!FLEXISIP_PORT!5065!g"
#!substdef "!DB_URL!postgres://__DB_USER__:__DB_PASS__@__DB_HOST__:5432/__DB_NAME__!g"

# ---- Module Loading ----

loadmodule "tm.so"
loadmodule "tmx.so"
loadmodule "sl.so"
loadmodule "rr.so"
loadmodule "pv.so"
loadmodule "maxfwd.so"
loadmodule "usrloc.so"
loadmodule "registrar.so"
loadmodule "textops.so"
loadmodule "siputils.so"
loadmodule "xlog.so"
loadmodule "sanity.so"
loadmodule "nathelper.so"
loadmodule "rtpengine.so"
loadmodule "auth.so"
loadmodule "auth_db.so"
loadmodule "db_postgres.so"
loadmodule "dispatcher.so"
loadmodule "tls.so"
loadmodule "websocket.so"
loadmodule "xhttp.so"
loadmodule "htable.so"
loadmodule "pike.so"
loadmodule "dialog.so"
loadmodule "presence.so"
loadmodule "presence_xml.so"
loadmodule "jsonrpcs.so"

# ---- Module Parameters ----

# TLS
modparam("tls", "config", "/etc/kamailio/tls.cfg")
modparam("tls", "tls_force_run", 1)

# User Location (registration database)
modparam("usrloc", "db_url", "DB_URL")
modparam("usrloc", "db_mode", 2)
modparam("usrloc", "use_domain", 1)

# Registrar
modparam("registrar", "method_filtering", 1)
modparam("registrar", "max_expires", 3600)
modparam("registrar", "min_expires", 60)
modparam("registrar", "default_expires", 600)
modparam("registrar", "gruu_enabled", 1)

# Authentication
modparam("auth_db", "db_url", "DB_URL")
modparam("auth_db", "calculate_ha1", 1)
modparam("auth_db", "password_column", "password")
modparam("auth_db", "load_credentials", "")
modparam("auth_db", "use_domain", 1)

# NAT Traversal
modparam("nathelper", "natping_interval", 30)
modparam("nathelper", "ping_nated_only", 1)
modparam("nathelper", "sipping_bflag", 7)
modparam("nathelper", "sipping_from", "sip:keepalive@MY_DOMAIN")

# RTPEngine (media relay for NAT)
modparam("rtpengine", "rtpengine_sock", "udp:127.0.0.1:22222")

# Dispatcher (load balance to FreeSWITCH instances)
modparam("dispatcher", "db_url", "DB_URL")
modparam("dispatcher", "ds_ping_method", "OPTIONS")
modparam("dispatcher", "ds_ping_interval", 10)
modparam("dispatcher", "ds_probing_mode", 1)

# Dialog tracking
modparam("dialog", "db_url", "DB_URL")
modparam("dialog", "db_mode", 1)

# Anti-flood
modparam("pike", "sampling_time_unit", 2)
modparam("pike", "reqs_density_per_unit", 30)
modparam("pike", "remove_latency", 4)

# Presence (BLF)
modparam("presence", "db_url", "DB_URL")
modparam("presence", "subs_db_mode", 2)

# ---- Listen Addresses ----

listen=udp:MY_IP:5060
listen=tcp:MY_IP:5060
listen=tls:MY_IP:5061
listen=tls:MY_IP:MY_WS_PORT

# ---- Main Request Routing ----

request_route {
    # Per-request sanity checks
    if (!mf_process_maxfwd_header("10")) {
        sl_send_reply("483", "Too Many Hops");
        exit;
    }

    if (!sanity_check("17895", "7")) {
        xlog("L_WARN", "Malformed SIP from $si:$sp\n");
        exit;
    }

    # Anti-flood protection
    if (!pike_check_req()) {
        xlog("L_WARN", "PIKE: rate limit exceeded from $si\n");
        sl_send_reply("503", "Service Unavailable");
        exit;
    }

    # NAT detection and fix
    if (nat_uac_test("19")) {
        if (is_method("REGISTER")) {
            fix_nated_register();
        } else {
            fix_nated_contact();
            force_rport();
        }
    }

    # Record-Route for mid-dialog requests
    if (is_method("INVITE|SUBSCRIBE")) {
        record_route();
    }

    # Handle mid-dialog requests (re-INVITE, BYE, ACK, etc.)
    if (has_totag()) {
        if (loose_route()) {
            if (is_method("INVITE")) {
                # RTP relay for re-INVITE
                rtpengine_manage("replace-origin replace-session-connection");
            }
            route(RELAY);
            exit;
        }
    }

    # CANCEL processing
    if (is_method("CANCEL")) {
        if (t_check_trans()) {
            route(RELAY);
        }
        exit;
    }

    # Handle REGISTER
    if (is_method("REGISTER")) {
        route(AUTH);
        if (!save("location")) {
            sl_send_reply("503", "Service Unavailable");
        }
        exit;
    }

    # Handle SUBSCRIBE/PUBLISH (presence/BLF)
    if (is_method("SUBSCRIBE")) {
        route(AUTH);
        route(PRESENCE);
        exit;
    }

    if (is_method("PUBLISH")) {
        route(AUTH);
        route(PRESENCE);
        exit;
    }

    # Handle INVITE
    if (is_method("INVITE")) {
        route(AUTH);
        route(INVITE);
        exit;
    }

    # Handle MESSAGE (quick messages between extensions)
    if (is_method("MESSAGE")) {
        route(AUTH);
        route(MESSAGE);
        exit;
    }

    # Default: relay
    route(RELAY);
}

# ---- Authentication Route ----

route[AUTH] {
    if (is_method("REGISTER") || from_uri == myself) {
        if (!auth_check("MY_DOMAIN", "subscriber", "1")) {
            auth_challenge("MY_DOMAIN", "1");
            exit;
        }
    }
}

# ---- INVITE Routing ----

route[INVITE] {
    # Create dialog for call tracking
    dlg_manage();

    # Check if destination is a local extension
    if ($rU =~ "^[1-9][0-9]{3}$") {
        # Local extension — look up registration
        if (!lookup("location")) {
            # Not registered — send to Flexisip for push notification
            xlog("L_INFO", "Extension $rU not registered, sending push via Flexisip\n");
            $du = "sip:FLEXISIP_IP:FLEXISIP_PORT";
            route(RELAY);
            exit;
        }
        # RTP relay
        rtpengine_manage("replace-origin replace-session-connection");
        route(RELAY);
        exit;
    }

    # Conference bridge (*85xxx)
    if ($rU =~ "^\*85") {
        route(TO_FREESWITCH);
        exit;
    }

    # Voicemail (*97)
    if ($rU =~ "^\*97$") {
        route(TO_FREESWITCH);
        exit;
    }

    # PSTN outbound (10+ digits)
    if ($rU =~ "^\+?[0-9]{10,15}$") {
        route(TO_FREESWITCH);
        exit;
    }

    # Unknown destination
    sl_send_reply("404", "Not Found");
    exit;
}

# ---- Route to FreeSWITCH (via dispatcher for load balancing) ----

route[TO_FREESWITCH] {
    # Dispatch set 1 = FreeSWITCH instances
    if (!ds_select_dst("1", "4")) {
        # Fallback: direct to primary FreeSWITCH
        $du = "sip:FS_IP:FS_PORT";
    }
    rtpengine_manage("replace-origin replace-session-connection");
    route(RELAY);
}

# ---- Presence Route (BLF/SUBSCRIBE) ----

route[PRESENCE] {
    if (!t_newtran()) {
        sl_reply_error();
        exit;
    }
    handle_subscribe();
    exit;
}

# ---- MESSAGE Route ----

route[MESSAGE] {
    if (!lookup("location")) {
        sl_send_reply("404", "User Not Found");
        exit;
    }
    route(RELAY);
}

# ---- Relay Route ----

route[RELAY] {
    if (!t_relay()) {
        sl_reply_error();
    }
    exit;
}

# ---- Reply Route ----

onreply_route {
    if (nat_uac_test("1")) {
        fix_nated_contact();
    }
    if (has_body("application/sdp")) {
        rtpengine_manage("replace-origin replace-session-connection");
    }
}

# ---- Failure Route ----

failure_route[INVITE_FAILURE] {
    if (t_is_canceled()) {
        exit;
    }

    # On busy or no answer, forward to voicemail via FreeSWITCH
    if (t_check_status("486|408|480")) {
        xlog("L_INFO", "Call failed ($T_reply_code), routing to voicemail\n");
        $rU = "*97" + $rU;
        route(TO_FREESWITCH);
        exit;
    }
}

# ---- WebSocket (WSS) handling for WebRTC clients ----

event_route[xhttp:request] {
    if ($hdr(Upgrade) =~ "websocket" && $hdr(Connection) =~ "Upgrade") {
        if (ws_handle_handshake()) {
            exit;
        }
    }
    xhttp_reply("404", "Not Found", "text/plain", "Not here\n");
}
