# =============================================================================
# phone11 UCC Platform — Environment Variables
# Copy this file to .env and fill in real values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/cloudphone11
REDIS_URL=redis://127.0.0.1:6379

# --- SIP / VoIP ---
SIP_DOMAIN=sip.phone11.ai
SIP_DEK_SECRET=generate-a-strong-random-secret-here
KAMAILIO_SECRET=generate-a-kamailio-api-secret-here

# --- FreeSWITCH ---
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=change-me

# --- Push Notifications ---
APPLE_PUSH_CERT_PATH=/path/to/apns-cert.pem
APPLE_PUSH_KEY_PATH=/path/to/apns-key.pem
APPLE_PUSH_BUNDLE_ID=com.phone11.app
FCM_API_KEY=your-firebase-cloud-messaging-key

# --- OAuth / Auth ---
JWT_SECRET=generate-a-jwt-secret-here
OAUTH_SERVER_URL=https://your-oauth-server.com

# --- AWS (for S3 recordings, if applicable) ---
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_RECORDINGS_BUCKET=phone11-recordings

# --- LLM / AI Features ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- BillRun / Billing ---
BILLRUN_API_URL=http://localhost:8080
BILLRUN_API_KEY=your-billrun-api-key

# --- App Config ---
NODE_ENV=development
PORT=3000
